# Environment Variables for Kisan Cold Keep Bookings

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=AgroChillBookingDB

# OpenRouteService API Key (optional - for enhanced routing)
# Free tier: 2000 requests/day
# Get your API key from: https://openrouteservice.org/dev/#/signup
# Leave empty to use only OpenStreetMap (Nominatim) for geocoding
ORS_API_KEY=your_openrouteservice_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
